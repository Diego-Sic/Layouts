<?xml version="1.0" encoding="UTF-8" ?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>
<VBox
    alignment="TOP_CENTER"
    prefHeight="560"
    prefWidth="620"
    spacing="12"
    style="-fx-background-color: #C0C0C0;"
    xmlns="http://javafx.com/javafx/25"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="TripRequirementsController"
>

    <padding>
        <Insets bottom="25" left="40" right="40" top="25" />
    </padding>

    <!-- Title -->
    <Text
        style="-fx-font-size: 24; -fx-font-weight: bold; -fx-font-family: Arial;"
        text="TRIP REQUIREMENTS"
    >
        <VBox.margin>
            <Insets bottom="5" />
        </VBox.margin>
    </Text>

    <!-- Subtitle -->
    <Text
        style="-fx-font-size: 14; -fx-font-family: Arial;"
        text="Please, Enter TRIP REQUIREMENTS"
    >
        <VBox.margin>
            <Insets bottom="10" top="5" />
        </VBox.margin>
    </Text>

    <!-- Form Fields -->
    <GridPane
        alignment="CENTER_LEFT"
        hgap="15"
        prefHeight="150.0"
        prefWidth="378.0"
        vgap="12"
    >
        <VBox.margin>
            <Insets bottom="10" left="40" right="40" />
        </VBox.margin>

        <columnConstraints>
            <ColumnConstraints minWidth="80" prefWidth="80" />
            <ColumnConstraints minWidth="200" prefWidth="250" />
        </columnConstraints>

        <!-- From -->
        <Label
            style="-fx-font-size: 14; -fx-font-family: Arial;"
            text="From"
            GridPane.columnIndex="0"
            GridPane.rowIndex="0"
            GridPane.valignment="CENTER"
        />
        <TextField
            fx:id="fromField"
            prefHeight="48.0"
            prefWidth="250.0"
            text="Atlanta"
            GridPane.columnIndex="1"
            GridPane.rowIndex="0"
        />

        <!-- To -->
        <Label
            style="-fx-font-size: 14; -fx-font-family: Arial;"
            text="To"
            GridPane.columnIndex="0"
            GridPane.rowIndex="1"
            GridPane.valignment="CENTER"
        />
        <TextField
            fx:id="toField"
            prefHeight="27.0"
            prefWidth="345.0"
            text="Crete"
            GridPane.columnIndex="1"
            GridPane.rowIndex="1"
        />

        <!-- Date -->
        <Label
            style="-fx-font-size: 14; -fx-font-family: Arial;"
            text="Date"
            GridPane.columnIndex="0"
            GridPane.rowIndex="2"
            GridPane.valignment="CENTER"
        />
        <HBox
            alignment="CENTER_LEFT"
            spacing="8"
            GridPane.columnIndex="1"
            GridPane.rowIndex="2"
        >
            <TextField
                fx:id="yearField"
                prefHeight="28"
                prefWidth="60"
                text="2002"
            />
            <TextField
                fx:id="monthField"
                prefHeight="28"
                prefWidth="45"
                text="05"
            />
            <TextField
                fx:id="dayField"
                prefHeight="28"
                prefWidth="45"
                text="25"
            />
        </HBox>

        <!-- Length of stay -->
        <Label
            style="-fx-font-size: 14; -fx-font-family: Arial;"
            text="Length&#10;of stay"
            wrapText="true"
            GridPane.columnIndex="0"
            GridPane.rowIndex="3"
            GridPane.valignment="CENTER"
        />
        <HBox
            alignment="CENTER_LEFT"
            spacing="10"
            GridPane.columnIndex="1"
            GridPane.rowIndex="3"
        >
            <TextField
                fx:id="stayField"
                prefHeight="28"
                prefWidth="50"
                text="1"
            />
            <Label
                style="-fx-font-size: 14; -fx-font-family: Arial;"
                text="Week"
            />
        </HBox>
      <rowConstraints>
         <RowConstraints />
         <RowConstraints />
         <RowConstraints />
         <RowConstraints />
      </rowConstraints>
    </GridPane>

    <!-- Number of People Group -->
    <StackPane>
        <VBox.margin>
            <Insets bottom="5" left="15" right="15" top="5" />
        </VBox.margin>

        <!-- Border box -->
        <VBox
            style="-fx-border-color: #808080; -fx-border-width: 1; -fx-padding: 20 15 15 15;"
        >
            <HBox alignment="CENTER_LEFT" spacing="40">
                <padding>
                    <Insets bottom="10" left="10" right="10" top="10" />
                </padding>

                <!-- Left column -->
                <VBox spacing="15">
                    <!-- Adults -->
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <TextField
                            fx:id="adultsField"
                            prefHeight="28"
                            prefWidth="45"
                            text="2"
                        />
                        <Label
                            style="-fx-font-size: 14; -fx-font-family: Arial;"
                            text="Adults"
                            wrapText="true"
                        />
                    </HBox>
                    <!-- Youth -->
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <TextField
                            fx:id="youthField"
                            prefHeight="28"
                            prefWidth="45"
                        />
                        <Label
                            prefWidth="140"
                            style="-fx-font-size: 14; -fx-font-family: Arial;"
                            text="Youth&#10;(12 - 17 years old)"
                            wrapText="true"
                        />
                    </HBox>
                </VBox>

                <!-- Right column -->
                <VBox spacing="15">
                    <!-- Children 2-11 -->
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <TextField
                            fx:id="childrenField"
                            prefHeight="28"
                            prefWidth="45"
                            text="2"
                        />
                        <Label
                            prefWidth="170"
                            style="-fx-font-size: 14; -fx-font-family: Arial;"
                            text="Children&#10;from 2 to 11 years old"
                            wrapText="true"
                        />
                    </HBox>
                    <!-- Children under 2 -->
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <TextField
                            fx:id="infantField"
                            prefHeight="28"
                            prefWidth="45"
                        />
                        <Label
                            prefWidth="170"
                            style="-fx-font-size: 14; -fx-font-family: Arial;"
                            text="Children&#10;under 2 years old"
                            wrapText="true"
                        />
                    </HBox>
                </VBox>
            </HBox>
        </VBox>

        <!-- Group label -->
        <Label
            style="-fx-background-color: #C0C0C0; -fx-font-size: 14; -fx-font-family: Arial;"
            text="  Number of People  "
            translateY="-10"
            StackPane.alignment="TOP_LEFT"
        >
            <StackPane.margin>
                <Insets left="20" />
            </StackPane.margin>
        </Label>
    </StackPane>

    <!-- Instruction text -->
    <Text
        style="-fx-font-size: 14; -fx-font-family: Arial;"
        text="When you have completed TRIP REQUIREMENTS form, please click on FIND button"
        wrappingWidth="520"
    >
        <VBox.margin>
            <Insets bottom="5" top="8" />
        </VBox.margin>
    </Text>

    <!-- Buttons -->
    <HBox>
        <padding>
            <Insets top="5" />
        </padding>
        <Button
            onAction="#handleFind"
            prefHeight="31.0"
            prefWidth="221.0"
            style="-fx-font-size: 14; -fx-font-family: Arial;"
            text="Find"
        />
        <Region HBox.hgrow="ALWAYS" />
        <Button
            onAction="#handleEscape"
            prefHeight="32.0"
            prefWidth="238.0"
            style="-fx-font-size: 14; -fx-font-family: Arial;"
            text="Escape"
        />
    </HBox>

</VBox>
